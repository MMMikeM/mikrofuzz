{
  "name": "@mmmike/mikrofuzz",
  "version": "1.0.0",
  "description": "Zero-dependency fuzzy search library with smart word-boundary matching",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt src test",
    "lint:types": "tsc --noEmit",
    "test": "vitest run",
    "bench": "pnpm build && pnpm --filter=@mmmike/mikrofuzz-bench bench",
    "prepublishOnly": "pnpm lint:types && pnpm test && pnpm build"
  },
  "keywords": [
    "fuzzy-search",
    "search",
    "filter",
    "autocomplete",
    "microfuzz"
  ],
  "license": "MIT",
  "author": "Mike <mikem.tba@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/MMMikeM/mikrofuzz.git"
  },
  "homepage": "https://github.com/MMMikeM/mikrofuzz#readme",
  "bugs": {
    "url": "https://github.com/MMMikeM/mikrofuzz/issues"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}